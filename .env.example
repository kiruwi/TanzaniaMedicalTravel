NUXT_SITE_URL=https://example-medical-travel.com
NUXT_ADMIN_EMAIL=admin@example.com

# Browser-safe Supabase config. Required for login, password reset, and client auth.
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Server-only Supabase service credential. Required for admin APIs, sync jobs, audit logs, and writes that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

STRIPE_SECRET_KEY=
RESEND_API_KEY=
RESEND_FROM=care@example-medical-travel.com
STRAPI_URL=
STRAPI_TOKEN=
NUXT_PUBLIC_STRAPI_URL=
NUXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NUXT_PUBLIC_SUPPORT_EMAIL=care@example-medical-travel.com
